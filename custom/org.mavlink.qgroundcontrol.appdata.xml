  <summary>Open Source Ground Control App</summary>
  <description>
    <p>
      QGroundControl (QGC) is a highly intuitive and powerful Ground Control Station (GCS) designed for UAVs.
      Whether you're a first-time pilot or an experienced professional,
      QGC provides a seamless user experience for flight control and mission planning,
      making it the go-to solution for any MAVLink-enabled drone.
    </p>
  </description>
  <icon type="stock">Custom-QGroundControl</icon>

  <provides>
    <binary>Custom-QGroundControl</binary>
  </provides>

  <releases>
    <release version="5.0.3" date="2026-05-19T22:46:29-04:00">
      <description>
        <p>Rebuilt with CMake for Qt6.8</p>
      </description>
    </release>
  </releases>

  <screenshots>
